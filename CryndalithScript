<!DOCTYPE html>

<html lang="en">

<head>

    <meta charset="UTF-8">

    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>CRYNDALITH • FILE VAULT</title>

    <style>

        @import url('https://fonts.googleapis.com/css2?family=VT323&display=swap');



        :root {

            --void: #0a0a0f;

            --deep: #12121a;

            --accent: #5c2a9e;

            --glow: #9b6eff;

            --text: #c4b3ff;

            --red: #ff3366;

        }



        * { margin: 0; padding: 0; box-sizing: border-box; }



        body {

            background: var(--void);

            color: var(--text);

            font-family: 'VT323', monospace;

            line-height: 1.5;

            background-image:

                radial-gradient(circle at 30% 20%, rgba(155, 110, 255, 0.05) 0%, transparent 60%),

                radial-gradient(circle at 70% 80%, rgba(92, 42, 158, 0.06) 0%, transparent 60%);

        }



        .noise { 

            position: fixed; top: 0; left: 0; width: 100%; height: 100%; 

            background: url('https://picsum.photos/id/1015/800/800') repeat; 

            opacity: 0.03; mix-blend-mode: overlay; z-index: -2; pointer-events: none; 

        }



        .scanlines { 

            position: fixed; top: 0; left: 0; width: 100%; height: 100%; 

            background: repeating-linear-gradient(transparent 0px, transparent 3px, rgba(0,0,0,0.25) 3px, rgba(0,0,0,0.25) 6px); 

            z-index: 9999; pointer-events: none; 

        }



        .admin-bar {

            background: #1a0f2e;

            border-bottom: 4px solid var(--red);

            padding: 14px 25px;

            font-size: 1.35rem;

            color: #ff99cc;

            text-shadow: 0 0 8px #ff3366;

        }



        header { text-align: center; padding: 50px 20px 30px; }

        h1 { font-size: 4.2rem; color: #d1b8ff; letter-spacing: 6px; text-shadow: 0 0 15px var(--glow); }

        .subtitle { font-size: 1.35rem; color: #8a6fc9; margin-top: 8px; }



        .main { max-width: 1100px; margin: 0 auto; padding: 30px; }



        .section {

            background: rgba(18, 15, 35, 0.95);

            border: 3px solid var(--accent);

            padding: 30px;

            margin-bottom: 50px;

            box-shadow: 0 0 40px rgba(155, 110, 255, 0.2);

        }



        .section h2 { 

            font-size: 2.4rem; color: var(--glow); margin-bottom: 25px; 

            text-shadow: 0 0 12px var(--glow); 

        }



        .dump-grid {

            display: grid;

            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));

            gap: 25px;

        }



        .dump-card {

            background: var(--deep);

            border: 3px solid var(--accent);

            padding: 15px;

            transition: all 0.3s;

        }



        .dump-card:hover { 

            border-color: var(--glow); 

            box-shadow: 0 0 30px var(--glow); 

            transform: translateY(-6px); 

        }



        .dump-video, .dump-file {

            width: 100%;

            height: 170px;

            background: #000;

            border: 2px solid #3a2a5c;

            display: flex;

            align-items: center;

            justify-content: center;

            font-size: 4rem;

            color: rgba(155, 110, 255, 0.4);

            cursor: pointer;

        }



        .dump-card .label { 

            text-align: center; margin-top: 12px; font-size: 1.35rem; 

            color: #d1b8ff; word-break: break-all; 

        }



        .pic {

            width: 100%;

            height: 240px;

            object-fit: cover;

            border: 3px solid var(--accent);

            transition: all 0.3s;

        }



        .pic:hover { 

            border-color: var(--glow); 

            box-shadow: 0 0 25px var(--glow); 

            transform: scale(1.03); 

        }



        .dump-form {

            background: var(--deep);

            padding: 25px;

            border: 3px solid var(--accent);

            margin-top: 30px;

        }



        .dump-form input, .dump-form textarea {

            width: 100%;

            background: #0a0a0f;

            border: 2px solid #5c2a9e;

            color: var(--text);

            font-family: 'VT323', monospace;

            font-size: 1.25rem;

            padding: 15px;

            margin-bottom: 15px;

        }



        .dump-form button {

            background: #5c2a9e;

            color: white;

            border: 3px solid var(--glow);

            padding: 14px 35px;

            font-family: 'VT323', monospace;

            font-size: 1.55rem;

            cursor: pointer;

        }



        .dump-form button:hover { 

            background: var(--glow); 

            color: #0a0a0f; 

        }



        .warning-box {

            background: rgba(255, 51, 102, 0.25);

            border: 4px solid var(--red);

            padding: 25px;

            margin: 30px 0;

            color: #ff99cc;

            font-size: 1.4rem;

            line-height: 1.7;

        }

    </style>

</head>

<body>

    <div class="noise"></div>

    <div class="scanlines"></div>



    <div class="admin-bar">

        CRYNDALITH FILE VAULT — Purely client-side • Runs only in your browser • No server • No tracking

    </div>



    <header>

        <h1>CRYNDALITH</h1>

        <p class="subtitle">FILE VAULT • MEDIA LINKS • LOCAL ONLY</p>

    </header>



    <div class="main">



        <!-- Legal Notice -->

        <div class="section" style="border-color:#ff3366; background:rgba(30,10,20,0.95);">

            <h2 style="color:#ff3366;">LEGAL NOTICE — READ THIS</h2>

            <div class="warning-box">

                This is a 100% local HTML tool. Nothing is uploaded or stored on any server.<br><br>

                <strong>You are solely responsible for every link you add or share.</strong><br>

                Only use it for content that is legal in your jurisdiction.

            </div>

        </div>



        <!-- Video Section -->

        <div class="section">

            <h2>Video Links</h2>

            <div class="dump-grid" id="videoGrid"></div>

            <div class="dump-form">

                <h3>Add Video Link</h3>

                <input type="text" id="videoUrl" placeholder="Direct .mp4 / .webm link">

                <input type="text" id="videoTitle" placeholder="Name (optional)">

                <button onclick="addVideo()">Add Video</button>

            </div>

        </div>



        <!-- Image Section -->

        <div class="section">

            <h2>Image Links</h2>

            <div class="dump-grid" id="pictureGrid"></div>

            <div class="dump-form">

                <h3>Add Image Link</h3>

                <input type="text" id="imageUrl" placeholder="Direct image link (jpg, png, webp...)">

                <button onclick="addImage()">Add Image</button>

            </div>

        </div>



        <!-- General Files -->

        <div class="section">

            <h2>General Files (PDF, ZIP, Audio, Docs, etc.)</h2>

            <div class="dump-grid" id="fileGrid"></div>

            <div class="dump-form">

                <h3>Add Any File Link</h3>

                <input type="text" id="fileUrl" placeholder="Direct file link">

                <input type="text" id="fileTitle" placeholder="File name / description">

                <button onclick="addFile()">Add File</button>

            </div>

        </div>



        <!-- Export / Import -->

        <div class="section">

            <h2>Export / Import Collection</h2>

            <div class="dump-form">

                <h3>Generate Shareable JSON</h3>

                <textarea id="jsonBlob" readonly style="height: 280px;"></textarea>

                <button onclick="generateJSON()">Generate JSON</button>

                <p style="margin-top:15px; color:#ff9999;">

                    Copy the JSON → save as <strong>myvault.json</strong> → host it anywhere you want.

                </p>

            </div>



            <div class="dump-form" style="margin-top:30px;">

                <h3>Load Collection from URL</h3>

                <input type="text" id="loadUrl" placeholder="https://your-link-to/vault.json">

                <button onclick="loadCollection()">Load Collection</button>

            </div>

        </div>



    </div>



    <footer style="text-align:center; padding:60px 20px; color:#553377; font-size:1.25rem;">

        CRYNDALITH FILE VAULT • Pure client-side • Free forever

    </footer>



    <script>

        let videos = JSON.parse(localStorage.getItem('cry_videos') || '[]');

        let images = JSON.parse(localStorage.getItem('cry_images') || '[]');

        let files = JSON.parse(localStorage.getItem('cry_files') || '[]');



        function saveData() {

            localStorage.setItem('cry_videos', JSON.stringify(videos));

            localStorage.setItem('cry_images', JSON.stringify(images));

            localStorage.setItem('cry_files', JSON.stringify(files));

        }



        function renderAll() {

            // Videos

            const vGrid = document.getElementById('videoGrid');

            vGrid.innerHTML = '';

            videos.forEach((v, i) => {

                const card = document.createElement('div');

                card.className = 'dump-card';

                card.innerHTML = `

                    <div class="dump-video" onclick="window.open('${v.url}', '_blank')">▶</div>

                    <div class="label">${v.title || 'Video'}</div>

                `;

                vGrid.appendChild(card);

            });



            // Images

            const pGrid = document.getElementById('pictureGrid');

            pGrid.innerHTML = '';

            images.forEach(img => {

                const card = document.createElement('div');

                card.className = 'dump-card';

                card.innerHTML = `

                    <img src="${img.url}" class="pic" alt="image" onerror="this.style.display='none'">

                    <div class="label">IMAGE</div>

                `;

                pGrid.appendChild(card);

            });



            // General Files

            const fGrid = document.getElementById('fileGrid');

            fGrid.innerHTML = '';

            files.forEach(f => {

                const card = document.createElement('div');

                card.className = 'dump-card';

                card.innerHTML = `

                    <div class="dump-file" onclick="window.open('${f.url}', '_blank')">📄</div>

                    <div class="label">${f.title || 'File'}</div>

                `;

                fGrid.appendChild(card);

            });

        }



        function addVideo() {

            const url = document.getElementById('videoUrl').value.trim();

            const title = document.getElementById('videoTitle').value.trim();

            if (url) {

                videos.push({ url, title });

                saveData();

                renderAll();

                document.getElementById('videoUrl').value = '';

                document.getElementById('videoTitle').value = '';

            }

        }



        function addImage() {

            const url = document.getElementById('imageUrl').value.trim();

            if (url) {

                images.push({ url });

                saveData();

                renderAll();

                document.getElementById('imageUrl').value = '';

            }

        }



        function addFile() {

            const url = document.getElementById('fileUrl').value.trim();

            const title = document.getElementById('fileTitle').value.trim();

            if (url) {

                files.push({ url, title });

                saveData();

                renderAll();

                document.getElementById('fileUrl').value = '';

                document.getElementById('fileTitle').value = '';

            }

        }



        function generateJSON() {

            const data = { videos, images, files };

            const jsonStr = JSON.stringify(data, null, 2);

            document.getElementById('jsonBlob').value = jsonStr;

        }



        function loadCollection() {

            const url = document.getElementById('loadUrl').value.trim();

            if (!url) return;



            fetch(url)

                .then(res => res.json())

                .then(data => {

                    if (data.videos) videos = data.videos;

                    if (data.images) images = data.images;

                    if (data.files) files = data.files;

                    saveData();

                    renderAll();

                    alert("Collection loaded successfully!");

                })

                .catch(err => {

                    alert("Failed to load collection. Make sure the URL points to a valid JSON file.");

                    console.error(err);

                });

        }



        // Initialize

        window.onload = renderAll;

    </script>

</body>
